{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist/client",
    "rootDir": "./src/client",
    "jsx": "react-jsx",
    "resolveJsonModule": true
  },
  "include": ["src/client/**/*"],
  "exclude": ["node_modules", "dist"]
}
